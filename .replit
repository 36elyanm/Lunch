run = "python -m pip install -r requirements.txt && python -m gunicorn app:app --bind 0.0.0.0:$PORT --timeout 120 --workers 2"

[agent]
expertMode = true

[deployment]
run = ["sh", "-c", "python -m pip install -r requirements.txt && python -m gunicorn app:app --bind 0.0.0.0:$PORT --timeout 120 --workers 2"]
deploymentTarget = "autoscale"
